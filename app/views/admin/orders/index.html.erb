<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Orders</h1>
    <%= link_to "New order", new_admin_order_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white block font-medium" %>
  </div>

  <h2 class="font-semibold text-2xl mt-8 mb-4">Unfulfilled Orders (Cozinha)</h2>
  <div class="flex flex-col w-full">
    <div class="overflow-x-auto">
      <table class="min-w-full bg-white border border-gray-200">
        <thead class="bg-gray-100 border-b">
          <tr>
            <th class="text-sm font-medium text-gray-800 px-6 py-4 text-left">Order ID</th>
            <th class="text-sm font-medium text-gray-800 px-6 py-4 text-left">E-mail</th>
            <th class="text-sm font-medium text-gray-800 px-6 py-4 text-left">Total</th>
            <th class="text-sm font-medium text-gray-800 px-6 py-4 text-left">Status</th>
            <th class="text-sm font-medium text-gray-800 px-6 py-4 text-left">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @not_fulfilled_orders.each do |o| %>
            <tr class="bg-white border-b hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600">
                <%= link_to o.id, [:admin, o], class: 'underline' %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"><%= o.customer_email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 font-bold">R$ <%= o.total %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%# Badge colorida baseada no status %>
                <span class="px-2 py-1 rounded text-xs font-bold <%= o.paid? ? 'bg-green-100 text-green-700' : 'bg-blue-100 text-blue-700' %>">
                  <%= o.status.upcase %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <div class="flex gap-2">
                  <% if o.paid? %>
                    <%= button_to 'Preparar', mark_as_preparing_admin_order_path(o), method: :patch, 
                        class: "bg-blue-500 hover:bg-blue-700 text-white text-xs py-1 px-3 rounded shadow" %>
                  <% elsif o.preparing? %>
                    <%= button_to 'Finalizar', mark_as_delivered_admin_order_path(o), method: :patch, 
                        class: "bg-green-500 hover:bg-green-700 text-white text-xs py-1 px-3 rounded shadow" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <h2 class="font-semibold text-2xl mt-12 mb-4 text-gray-500">Fulfilled Orders (Histórico)</h2>
  <div class="flex flex-col w-full opacity-75">
    <div class="overflow-x-auto">
      <table class="min-w-full bg-white border border-gray-200">
        <thead class="bg-gray-50 border-b">
          <tr>
            <th class="text-sm font-medium text-gray-600 px-6 py-4 text-left">Order ID</th>
            <th class="text-sm font-medium text-gray-600 px-6 py-4 text-left">E-mail</th>
            <th class="text-sm font-medium text-gray-600 px-6 py-4 text-left">Total</th>
            <th class="text-sm font-medium text-gray-600 px-6 py-4 text-left">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @fulfilled_orders.each do |o| %>
            <tr class="bg-gray-50 border-b">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= link_to o.id, [:admin, o], class: 'underline' %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= o.customer_email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">R$ <%= o.total %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="text-xs font-bold text-gray-500 underline">ENTREGUE</span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>